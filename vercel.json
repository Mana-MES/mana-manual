{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/artwork/(.*)", "destination": "/artwork/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/manuals/(.*)", "destination": "/manuals/$1" },
    { "source": "/IBM_Plex_Sans_Thai/(.*)", "destination": "/IBM_Plex_Sans_Thai/$1" },
    { "source": "/Inclusive_Sans/(.*)", "destination": "/Inclusive_Sans/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
